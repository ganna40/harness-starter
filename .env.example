# Copy this file to .env and fill in real values.
# Never commit .env. See SECURITY.md.

# --- App ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database ---
# Local Postgres instance. Create databases with:
#   createdb harness_starter
#   createdb harness_starter_test
# Then apply migrations:
#   npm run db:migrate
DATABASE_URL=postgres://postgres@localhost:5432/harness_starter
TEST_DATABASE_URL=postgres://postgres@localhost:5432/harness_starter_test
