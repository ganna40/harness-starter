{
  "name": "harness-starter",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-first development harness — templates, rules, scripts, evals.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "npm run typecheck && npm run lint && npm run test -- --run && npm run check:structure && npm run check:docs && npm run eval",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:structure": "node scripts/check-structure.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "eval": "node evals/harness/run.mjs",
    "score": "node scripts/quality-score.mjs",
    "cleanup:sweep": "node scripts/cleanup-sweep.mjs",
    "db:migrate": "tsx scripts/migrate.mjs",
    "db:migrate:test": "tsx scripts/migrate.mjs --test",
    "db:reset:test": "tsx scripts/db-reset-test.mjs",
    "notes": "tsx src/ui/cli/notes.ts",
    "serve": "tsx src/ui/http/main.ts",
    "dev": "tsx --watch src/ui/cli/notes.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "zod": "^3.24.1"
  }
}
